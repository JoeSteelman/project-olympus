generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppRole {
  ADMIN
  PLAYER
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  displayName String
  role        AppRole     @default(PLAYER)
  teamId      String?
  avatarKey   String      @default("zeus")
  avatarUrl   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  team        Team?       @relation(fields: [teamId], references: [id])
  entries     ScoreEntry[]
  playerState PlayerState?
  beerSent    BeerTransaction[] @relation("BeerFrom")
  beerReceived BeerTransaction[] @relation("BeerTo")
  notices     Notice[] @relation("NoticeCreatedBy")
  chairmanSessions GameSession[] @relation("ChairmanSessions")
  chairmanAssignments ChairmanAssignment[]
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  players   User[]
  results   ScoreEntry[]
  chairmanAssignments ChairmanAssignment[]
}

model Game {
  id                 String        @id @default(cuid())
  key                String        @unique
  name               String
  category           String
  description        String
  enabled            Boolean       @default(true)
  sortOrder          Int           @default(0)
  maxAvailablePoints Int           @default(0)
  scoringConfig      Json
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  entries            ScoreEntry[]
}

model EventConfig {
  id            String   @id @default(cuid())
  eventName      String   @default("Project Olympus")
  winningScore   Int      @default(500)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model ScoreEntry {
  id           String   @id @default(cuid())
  gameId        String
  teamId        String
  userId        String?
  teamPoints    Int      @default(0)
  playerPoints  Int      @default(0)
  metadata      Json?
  notes         String?
  createdAt     DateTime @default(now())
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId])
  @@index([teamId])
  @@index([userId])
}

enum SessionStatus {
  ACTIVE
  ENDED
}

enum NoticeKind {
  NOTICE
  TALKSHIT
}

model GameSession {
  id               String         @id @default(cuid())
  status           SessionStatus  @default(ACTIVE)
  startedAt        DateTime       @default(now())
  endedAt          DateTime?
  chairmanId       String?
  chairmanLocked   Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  chairman         User?          @relation("ChairmanSessions", fields: [chairmanId], references: [id])
  assignments      ChairmanAssignment[]
  notices          Notice[]
  beerTransactions BeerTransaction[]
}

model ChairmanAssignment {
  id         String      @id @default(cuid())
  sessionId  String
  userId     String
  teamId     String?
  assignedAt DateTime    @default(now())
  session    GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@index([teamId])
}

model PlayerState {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  beerBalance            Int      @default(10)
  beersReceived          Int      @default(0)
  talkShitCooldownUntil  DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BeerTransaction {
  id          String      @id @default(cuid())
  sessionId   String?
  fromUserId  String
  toUserId    String
  count       Int         @default(1)
  reason      String?
  createdAt   DateTime    @default(now())
  session     GameSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  fromUser    User        @relation("BeerFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User        @relation("BeerTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
}

model Notice {
  id          String      @id @default(cuid())
  sessionId   String?
  message     String
  kind        NoticeKind  @default(NOTICE)
  expiresAt   DateTime
  createdById String?
  createdAt   DateTime    @default(now())
  session     GameSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdBy   User?       @relation("NoticeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}
